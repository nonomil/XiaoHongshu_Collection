{
  "manifest_version": 3,
  "name": "XHS Local Ingress",
  "version": "0.1.0",
  "description": "Send the current page to the local XiaoHongShu collection workbench.",
  "permissions": [
    "activeTab",
    "tabs"
  ],
  "host_permissions": [
    "http://127.0.0.1/*"
  ],
  "background": {
    "service_worker": "service_worker.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "XHS Local Ingress"
  }
}
